import React, { useState, useEffect, useRef, useCallback } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import {
  MessageCircle,
  X,
  Send,
  Sparkles,
  TrendingUp,
  AlertTriangle,
  PartyPopper,
  Coffee,
  Moon,
  Sun,
  Zap,
  Heart,
  Target,
  Crown
} from 'lucide-react';
import { useAuth } from '../hooks/useAuth';

interface Message {
  id: string;
  role: 'user' | 'assistant';
  content: string;
  timestamp: Date;
  mood?: 'excited' | 'concerned' | 'encouraging' | 'celebratory' | 'calm';
  actions?: string[];
}

interface CompanionState {
  name: string;
  personality: 'supportive' | 'analytical' | 'energetic' | 'gentle';
  mood: 'happy' | 'concerned' | 'excited' | 'calm';
  energy: number; // 0-100
  userRelationship: 'new' | 'friend' | 'partner' | 'trusted';
  conversations: number;
  lastInteraction: Date | null;
}

const COMPANION_NAME = 'Vera';

export function AICompanion() {
  const { user } = useAuth();
  const [isOpen, setIsOpen] = useState(false);
  const [messages, setMessages] = useState<Message[]>([]);
  const [inputValue, setInputValue] = useState('');
  const [isTyping, setIsTyping] = useState(false);
  const [showGreeting, setShowGreeting] = useState(true);
  const [companionState, setCompanionState] = useState<CompanionState>({
    name: COMPANION_NAME,
    personality: 'supportive',
    mood: 'happy',
    energy: 80,
    userRelationship: 'new',
    conversations: 0,
    lastInteraction: null,
  });
  const messagesEndRef = useRef<HTMLDivElement>(null);

  const addMessage = useCallback((message: Message) => {
    setMessages(prev => [...prev, message]);
  }, []);

  // Welcome message on first open
  useEffect(() => {
    if (isOpen && messages.length === 0) {
      const hour = new Date().getHours();
      let greeting = 'Hey there!';
      let icon = <Sparkles className="w-4 h-4" />;

      if (hour < 12) {
        greeting = 'Good morning!';
        icon = <Sun className="w-4 h-4" />;
      } else if (hour < 17) {
        greeting = 'Good afternoon!';
        icon = <Coffee className="w-4 h-4" />;
      } else {
        greeting = 'Good evening!';
        icon = <Moon className="w-4 h-4" />;
      }

      const welcomeMessages = [
        `${greeting} I'm ${COMPANION_NAME}, your business companion. 💙`,
        "I'm here to help you understand your numbers and celebrate your wins!",
        "What would you like to know about your business today?"
      ];

      welcomeMessages.forEach((msg, index) => {
        setTimeout(() => {
          addMessage({
            id: `welcome-${index}`,
            role: 'assistant',
            content: msg,
            timestamp: new Date(),
            mood: 'excited',
          });
        }, index * 800);
      });
    }
  }, [isOpen, messages.length, addMessage]);

  // Auto-scroll to bottom
  useEffect(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [messages]);



  const generateResponse = useCallback((userMessage: string): { content: string; mood: 'excited' | 'concerned' | 'encouraging' | 'celebratory' | 'calm'; actions?: string[] } => {
    const lowerMsg = userMessage.toLowerCase();

    // Revenue queries
    if (lowerMsg.includes('revenue') || lowerMsg.includes('money') || lowerMsg.includes('sales')) {
      return {
        content: "Great question! Your revenue is looking strong this month. You've made ₹2.4L so far - that's 15% ahead of last month! 🚀\n\nWould you like to see a breakdown by category?",
        mood: 'celebratory',
        actions: ['View Revenue Breakdown', 'Compare with Last Month', 'Revenue Trends']
      };
    }

    // Expense queries
    if (lowerMsg.includes('expense') || lowerMsg.includes('spending') || lowerMsg.includes('cost')) {
      return {
        content: "I've been tracking your expenses closely. You're spending about ₹45K this month, which is within your budget. Your biggest category is Inventory (40%).\n\nFun fact: You've actually reduced miscellaneous expenses by 12% compared to last month! 🎉",
        mood: 'encouraging',
        actions: ['Expense Breakdown', 'Cost Optimization Tips', 'Budget Settings']
      };
    }

    // Growth queries
    if (lowerMsg.includes('growth') || lowerMsg.includes('improving') || lowerMsg.includes('better')) {
      return {
        content: "I love that you're thinking about growth! Your business has grown 34% this quarter - that's amazing! 📈\n\nBased on your patterns, I predict you could hit ₹30L next month if you maintain this momentum. Want to explore growth strategies?",
        mood: 'excited',
        actions: ['Growth Strategies', 'Set Growth Goals', 'Competitor Analysis']
      };
    }

    // Stress/Worry queries
    if (lowerMsg.includes('worried') || lowerMsg.includes('stress') || lowerMsg.includes('help') || lowerMsg.includes('problem')) {
      return {
        content: "I can hear the concern in your message, and I want you to know that it's completely normal to feel this way about your business. 💙\n\nTake a deep breath with me. You've overcome challenges before, and we'll figure this out together. What specifically is worrying you?",
        mood: 'calm',
        actions: ['Cash Flow Analysis', 'Stress Relief Tips', 'Talk to a Mentor']
      };
    }

    // Celebration/Mood queries
    if (lowerMsg.includes('good') || lowerMsg.includes('great') || lowerMsg.includes('happy') || lowerMsg.includes('amazing')) {
      return {
        content: "YES! I love hearing that! 🎉 Your positive energy is contagious!\n\nYou know what? You're absolutely crushing it. Building a business takes courage, and you're doing it every single day. I'm so proud to be on this journey with you!",
        mood: 'celebratory',
        actions: ['Share Your Win', 'Set New Goals', 'Celebrate']
      };
    }

    // Tax queries
    if (lowerMsg.includes('tax') || lowerMsg.includes('gst') || lowerMsg.includes('filing')) {
      return {
        content: "Tax season can feel overwhelming, but you're more prepared than you think! 📊\n\nI've organized all your transactions by GST category. You're actually in a great position - no surprises! Want me to generate your GST summary?",
        mood: 'calm',
        actions: ['GST Summary', 'Tax Calendar', 'Export Tax Data']
      };
    }

    // General/fallback responses
    const generalResponses: Array<{ content: string; mood: 'excited' | 'concerned' | 'encouraging' | 'celebratory' | 'calm'; actions: string[] }> = [
      {
        content: "That's an interesting question! Let me pull up your latest insights...\n\nActually, I noticed something exciting - your customer retention rate improved by 8% this month! Want to know what might be driving that?",
        mood: 'excited',
        actions: ['Customer Insights', 'Retention Strategies', 'Recent Changes']
      },
      {
        content: "I'm so glad you asked! 💫\n\nLooking at your data, you're consistently performing better than 70% of businesses in your category. That's something to be proud of! What specific area would you like to dive deeper into?",
        mood: 'encouraging',
        actions: ['Business Health', 'Category Benchmarks', 'Deep Analysis']
      },
      {
        content: "Hey, I was just thinking about you! I noticed you've been logging transactions regularly - that consistency is the foundation of great business decisions. 🌟\n\nWhat can I help you with today?",
        mood: 'calm',
        actions: ['Quick Stats', 'Recent Activity', 'Daily Insights']
      }
    ];

    return generalResponses[Math.floor(Math.random() * generalResponses.length)];
  }, []);

  const handleSend = async () => {
    if (!inputValue.trim()) return;

    const userMessage: Message = {
      id: `user-${Date.now()}`,
      role: 'user',
      content: inputValue,
      timestamp: new Date(),
    };

    addMessage(userMessage);
    setInputValue('');
    setIsTyping(true);

    // Simulate AI thinking time
    setTimeout(() => {
      const response = generateResponse(userMessage.content);

      addMessage({
        id: `assistant-${Date.now()}`,
        role: 'assistant',
        content: response.content,
        timestamp: new Date(),
        mood: response.mood,
        actions: response.actions,
      });

      setIsTyping(false);
      setCompanionState(prev => ({
        ...prev,
        conversations: prev.conversations + 1,
        lastInteraction: new Date(),
      }));
    }, 1500 + Math.random() * 1000);
  };

  const getMoodIcon = (mood?: string) => {
    switch (mood) {
      case 'excited': return <Zap className="w-4 h-4 text-yellow-400" />;
      case 'celebratory': return <PartyPopper className="w-4 h-4 text-pink-400" />;
      case 'concerned': return <Heart className="w-4 h-4 text-red-400" />;
      case 'encouraging': return <TrendingUp className="w-4 h-4 text-green-400" />;
      default: return <Sparkles className="w-4 h-4 text-[#00D4FF]" />;
    }
  };

  const getMoodColor = (mood?: string) => {
    switch (mood) {
      case 'excited': return 'bg-yellow-500/10 border-yellow-500/20';
      case 'celebratory': return 'bg-pink-500/10 border-pink-500/20';
      case 'concerned': return 'bg-red-500/10 border-red-500/20';
      case 'encouraging': return 'bg-green-500/10 border-green-500/20';
      default: return 'bg-[#00D4FF]/20 text-[#00D4FF]/10 border-blue-500/20';
    }
  };

  return (
    <>
      {/* Floating Action Button */}
      <motion.button
        className="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 text-white shadow-2xl flex items-center justify-center"
        whileHover={{ scale: 1.1 }}
        whileTap={{ scale: 0.95 }}
        onClick={() => setIsOpen(true)}
        initial={{ scale: 0, opacity: 0 }}
        animate={{ scale: 1, opacity: 1 }}
      >
        <MessageCircle className="w-6 h-6" />

        {/* Notification badge */}
        {showGreeting && (
          <span className="absolute -top-1 -right-1 w-5 h-5 bg-red-500 rounded-full flex items-center justify-center text-xs font-bold animate-pulse">
            1
          </span>
        )}
      </motion.button>

      {/* Chat Window */}
      <AnimatePresence>
        {isOpen && (
          <motion.div
            initial={{ opacity: 0, y: 20, scale: 0.95 }}
            animate={{ opacity: 1, y: 0, scale: 1 }}
            exit={{ opacity: 0, y: 20, scale: 0.95 }}
            className="fixed bottom-24 right-6 z-50 w-96 h-[500px] bg-[#0A0A0B] border border-white/10 rounded-2xl shadow-2xl overflow-hidden flex flex-col"
          >
            {/* Header */}
            <div className="p-4 bg-gradient-to-r from-blue-600/20 to-purple-600/20 border-b border-white/10 flex items-center justify-between">
              <div className="flex items-center gap-3">
                <div className="w-10 h-10 rounded-full bg-gradient-to-r from-blue-400 to-purple-400 flex items-center justify-center">
                  <Sparkles className="w-5 h-5 text-white" />
                </div>
                <div>
                  <h3 className="font-semibold text-white">{COMPANION_NAME}</h3>
                  <p className="text-xs text-[#00D4FF] flex items-center gap-1">
                    <span className="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
                    Your Business Companion
                  </p>
                </div>
              </div>
              <button
                onClick={() => setIsOpen(false)}
                className="p-2 hover:bg-white/10 rounded-full transition-colors"
              >
                <X className="w-5 h-5 text-[#C0C0C0]" />
              </button>
            </div>

            {/* Messages */}
            <div className="flex-1 overflow-y-auto p-4 space-y-4">
              {messages.map((message) => (
                <motion.div
                  key={message.id}
                  initial={{ opacity: 0, y: 10 }}
                  animate={{ opacity: 1, y: 0 }}
                  className={`flex ${message.role === 'user' ? 'justify-end' : 'justify-start'}`}
                >
                  <div className={`max-w-[85%] ${message.role === 'user' ? 'order-2' : 'order-1'}`}>
                    {message.role === 'assistant' && (
                      <div className="flex items-center gap-2 mb-1">
                        <span className="text-xs text-gray-500">{COMPANION_NAME}</span>
                        {getMoodIcon(message.mood)}
                      </div>
                    )}

                    <div className={`p-3 rounded-2xl ${message.role === 'user'
                      ? 'bg-[#00D4FF]/20 text-[#00D4FF] text-white'
                      : `bg-[#1A1A1B] text-white border ${getMoodColor(message.mood)}`
                      }`}>
                      <p className="text-sm leading-relaxed whitespace-pre-line">{message.content}</p>
                    </div>

                    {/* Quick Actions */}
                    {message.actions && message.role === 'assistant' && (
                      <div className="flex flex-wrap gap-2 mt-2">
                        {message.actions.map((action, idx) => (
                          <button
                            key={idx}
                            className="px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs text-[#00D4FF] transition-colors"
                          >
                            {action}
                          </button>
                        ))}
                      </div>
                    )}

                    <span className="text-xs text-gray-500 mt-1 block">
                      {message.timestamp.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                    </span>
                  </div>
                </motion.div>
              ))}

              {/* Typing Indicator */}
              {isTyping && (
                <motion.div
                  initial={{ opacity: 0 }}
                  animate={{ opacity: 1 }}
                  className="flex items-center gap-2"
                >
                  <div className="w-8 h-8 rounded-full bg-gradient-to-r from-blue-400 to-purple-400 flex items-center justify-center">
                    <Sparkles className="w-4 h-4 text-white" />
                  </div>
                  <div className="bg-[#1A1A1B] px-4 py-2 rounded-2xl flex items-center gap-1">
                    <motion.div
                      animate={{ y: [0, -5, 0] }}
                      transition={{ repeat: Infinity, duration: 0.5 }}
                      className="w-2 h-2 bg-blue-400 rounded-full"
                    />
                    <motion.div
                      animate={{ y: [0, -5, 0] }}
                      transition={{ repeat: Infinity, duration: 0.5, delay: 0.1 }}
                      className="w-2 h-2 bg-blue-400 rounded-full"
                    />
                    <motion.div
                      animate={{ y: [0, -5, 0] }}
                      transition={{ repeat: Infinity, duration: 0.5, delay: 0.2 }}
                      className="w-2 h-2 bg-blue-400 rounded-full"
                    />
                  </div>
                </motion.div>
              )}

              <div ref={messagesEndRef} />
            </div>

            {/* Input */}
            <div className="p-4 border-t border-white/10 bg-[#0A0A0B]">
              <div className="flex items-center gap-2">
                <input
                  type="text"
                  value={inputValue}
                  onChange={(e) => setInputValue(e.target.value)}
                  onKeyPress={(e) => e.key === 'Enter' && handleSend()}
                  placeholder="Ask me anything about your business..."
                  className="flex-1 bg-white/5 border border-white/10 rounded-full px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-blue-500"
                />
                <button
                  onClick={handleSend}
                  disabled={!inputValue.trim() || isTyping}
                  className="p-2.5 bg-[#00D4FF]/20 text-[#00D4FF] hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed rounded-full text-white transition-colors"
                >
                  <Send className="w-4 h-4" />
                </button>
              </div>

              {/* Quick Prompts */}
              <div className="flex gap-2 mt-3 overflow-x-auto">
                {['How am I doing?', 'Tax help', 'Growth tips', 'Cash flow'].map((prompt) => (
                  <button
                    key={prompt}
                    onClick={() => {
                      setInputValue(prompt);
                    }}
                    className="px-3 py-1 bg-white/5 hover:bg-white/10 rounded-full text-xs text-[#C0C0C0] whitespace-nowrap transition-colors"
                  >
                    {prompt}
                  </button>
                ))}
              </div>
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </>
  );
}

export default AICompanion;
