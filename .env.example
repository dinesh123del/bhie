NODE_ENV=development
PORT=5001
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/bhie?retryWrites=true&w=majority
JWT_SECRET=generate-a-64-char-secret-minimum
JWT_EXPIRES_IN=24h
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173
CLIENT_URL=http://localhost:5173
OPENAI_API_KEY=sk-...
CLAUDE_API_KEY=sk-ant-...
BODY_LIMIT=2mb
MAX_UPLOAD_FILE_SIZE_MB=10
REQUEST_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
UPLOAD_DIR=uploads

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-secret

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_verify_token

# Redis (Optional - for background jobs)
REDIS_URL=redis://localhost:6379

# Admin Seeding (Optional)
SEED_DEFAULT_ADMIN=false
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=minimum-12-characters
