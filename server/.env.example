# ─────────────────────────────────────────────────────
# Biz Plus Server — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env with real secrets to version control.

# --- CORE CONFIG ---
NODE_ENV=development
PORT=5001
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/biz-plus?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/biz-plus?retryWrites=true&w=majority
REDIS_URL=redis://localhost:6379
JWT_SECRET=generate_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=24h
CLIENT_URL=http://localhost:5173

# --- AUTH (GOOGLE OAUTH) ---
# Obtain from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- AI & ANALYTICS ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_VISION_MODEL=gpt-4o-mini
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_env
PINECONE_INDEX=your_pinecone_index
ML_SERVICE_URL=http://localhost:8000

# --- MONETIZATION (RAZORPAY) ---
RAZORPAY_KEY_ID=rzp_test_your_test_key
RAZORPAY_KEY_SECRET=your_razorpay_test_secret

# --- OPERATIONAL LIMITS ---
BODY_LIMIT=2mb
MAX_UPLOAD_FILE_SIZE_MB=10
REQUEST_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
UPLOAD_DIR=uploads
IMAGE_PROCESSING_CONCURRENCY=2

# --- WHATSAPP BUSINESS API (OPTIONAL) ---
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_verify_token

# --- SEED ADMIN (ENABLE FOR FIRST LAUNCH ONLY) ---
SEED_DEFAULT_ADMIN=false
ADMIN_SEED_EMAIL=admin@bizplus.ai
ADMIN_SEED_PASSWORD=pick_a_secure_password_minimum_12_chars
