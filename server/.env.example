# --- CORE CONFIG ---
NODE_ENV=production
PORT=5001
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/bhie?retryWrites=true&w=majority
JWT_SECRET=generate_a_long_random_string_for_production
JWT_EXPIRES_IN=24h
CLIENT_URL=https://your-frontend-vercel-link.app

# --- AI & ANALYTICS ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_VISION_MODEL=gpt-4o-mini
ML_SERVICE_URL=http://localhost:8000

# --- MONETIZATION (RAZORPAY) ---
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# --- SEED ADMIN (ENABLE FOR FIRST LAUNCH) ---
SEED_DEFAULT_ADMIN=true
ADMIN_SEED_EMAIL=admin@your-product-name.com
ADMIN_SEED_PASSWORD=pick_a_secure_password_for_first_login
