# Production Environment - Backend

# MongoDB - Use Atlas for production
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/bhie

# JWT Secret - Change to secure random string (min 32 chars)
JWT_SECRET=your_production_jwt_secret_minimum_32_characters_required
JWT_EXPIRES_IN=24h

# Server
PORT=4000
NODE_ENV=production

# Frontend URL - Your Vercel deployment
CLIENT_URL=https://your-app.vercel.app

# Payments
RAZORPAY_KEY_ID=rzp_live_SYwkStp5U2NhjF
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# AI
OPENAI_API_KEY=sk-your_production_key
BODY_LIMIT=2mb
MAX_UPLOAD_FILE_SIZE_MB=10
REQUEST_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
UPLOAD_DIR=uploads
