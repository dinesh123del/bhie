{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Node Backend",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server/server.js",
      "runtimeExecutable": "nodemon",
      "runtimeArgs": ["${workspaceFolder}/server/server.js"],
      "console": "integratedTerminal",
      "restart": true,
      "env": {
        "NODE_ENV": "development"
      }
    }
  ]
}
